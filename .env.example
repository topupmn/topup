# Database
DATABASE_URL="postgresql://user:password@localhost:5432/topup?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Reloadly (sandbox)
RELOADLY_CLIENT_ID=""
RELOADLY_CLIENT_SECRET=""
RELOADLY_ENV="sandbox"
RELOADLY_RECIPIENT_EMAIL="orders@topup.mn"
# sandbox: https://giftcards-sandbox.reloadly.com
# live: https://giftcards.reloadly.com

# QPay (sandbox)
QPAY_BASE_URL="https://merchant-sandbox.qpay.mn"
QPAY_USERNAME="TEST_MERCHANT"
QPAY_PASSWORD="123456"
QPAY_INVOICE_CODE="TEST_INVOICE"
QPAY_CALLBACK_URL="http://localhost:3000/api/qpay/webhook"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="topup.mn"
# Show "Sandbox: mark as paid" on order page (local dev only)
NEXT_PUBLIC_ENABLE_TEST_PAYMENT="false"
ALLOW_TEST_PAYMENT="false"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Use either TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID
TWILIO_FROM_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""

# Monitoring (Telegram hourly status)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
MONITORING_CRON_SECRET=""

# Admin panel — comma-separated admin emails
ADMIN_EMAILS="your-email@example.com"
# Buyer checkout is guest/phone-first. Enable only for temporary admin setup.
ALLOW_PUBLIC_REGISTRATION="false"
