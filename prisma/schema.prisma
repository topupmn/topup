generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  phone         String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id               String   @id @default(cuid())
  reloadlyId       Int
  name             String
  nameMn           String?
  brand            String
  category         String
  countryCode      String   @default("US")
  denominationUsd  Float
  priceMnt         Int
  imageUrl         String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orderItems OrderItem[]

  @@unique([reloadlyId, denominationUsd])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  FULFILLING
  DELIVERED
  FULFILLMENT_FAILED
  FAILED
  EXPIRED
  CANCELLED
}

enum SmsDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String?
  status      OrderStatus @default(PENDING_PAYMENT)
  subtotalMnt Int         @default(0)
  discountMnt Int         @default(0)
  discountCode String?
  discountPercent Float?
  totalMnt    Int
  email       String?
  phone       String
  guestAccessTokenHash String?
  smsStatus   SmsDeliveryStatus @default(PENDING)
  smsSentAt   DateTime?
  smsErrorMessage String?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  payment     Payment?
  fulfillment Fulfillment?

  @@index([userId])
  @@index([status])
}

model DiscountCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int    @default(1)
  unitMnt   Int
  totalMnt  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  qpayInvoiceId   String?       @unique
  qpayQrText      String?       @db.Text
  qpayQrImage     String?       @db.Text
  qpayBankUrls    Json?
  amountMnt       Int
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum FulfillmentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Fulfillment {
  id                  String            @id @default(cuid())
  orderId             String            @unique
  reloadlyTransactionId String?         @unique
  cardCode            String?           @db.Text
  cardPin             String?           @db.Text
  status              FulfillmentStatus @default(PENDING)
  errorMessage        String?
  deliveredAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id            String   @id @default("default")
  mntUsdRate    Int      @default(3500)
  markupPercent Float    @default(5)
  updatedAt     DateTime @updatedAt
}
